# Dotfiles zsh config (macOS + Arch). Symlinked to ~/.zshrc by install.sh.

# Resolve dotfiles root from this file's location (works through ~/.zshrc symlink).
if [[ -n "${ZSH_VERSION:-}" ]]; then
  _dotfiles_zshrc="${${(%):-%N}:-$0}"
  [[ -L "$_dotfiles_zshrc" ]] && _dotfiles_zshrc="$(readlink "$_dotfiles_zshrc")"
  export DOTFILES="$(cd "$(dirname "$_dotfiles_zshrc")/.." && pwd)"
  unset _dotfiles_zshrc
else
  export DOTFILES="${DOTFILES:-$HOME/dev/dotfiles}"
fi

# --- Prompt (git branch) ---
autoload -Uz vcs_info
setopt PROMPT_SUBST
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats ' %F{yellow}(%b)%f'
PROMPT='%F{cyan}%1~%f${vcs_info_msg_0_} ❯ '

# --- Tmux sessionizer (script installed by install.sh) ---
# Use $DOTFILES path directly: ~/bin/tmux-sessionizer can shadow ~/.local/bin.
_sessionizer="$DOTFILES/tmux/tmux-sessionizer"
if command -v fzf &>/dev/null && command -v tmux &>/dev/null && [[ -x "$_sessionizer" ]]; then
  alias ts="$_sessionizer"
  bindkey -s '^F' "$_sessionizer"$'\n'
fi
unset _sessionizer

# --- Passion Camp (optional local scripts) ---
passion-start() {
  if [[ -f "$HOME/dev/passion/start-passion-camp.sh" ]]; then
    cd "$HOME/dev/passion" && ./start-passion-camp.sh
  else
    echo "Passion Camp scripts not found at ~/dev/passion/"
  fi
}

passion-stop() {
  if [[ -f "$HOME/dev/passion/stop-passion-camp.sh" ]]; then
    cd "$HOME/dev/passion" && ./stop-passion-camp.sh
  else
    echo "Passion Camp scripts not found at ~/dev/passion/"
  fi
}

passion-restart() {
  if [[ -f "$HOME/dev/passion/restart-passion-camp.sh" ]]; then
    cd "$HOME/dev/passion" && ./restart-passion-camp.sh
  else
    echo "Passion Camp scripts not found at ~/dev/passion/"
  fi
}

alias pstart='passion-start'
alias pstop='passion-stop'
alias prestart='passion-restart'

# --- Claude / Codex ---
alias cld='claude --model sonnet'
alias cldy='claude --dangerously-skip-permissions --model sonnet'
alias cldyo='claude --dangerously-skip-permissions --model opus'
alias lfg='claude --dangerously-skip-permissions --model opus "/prime"'
alias cody='codex --dangerously-bypass-approvals-and-sandbox --model gpt-5.5'
alias codyx='codex --dangerously-bypass-approvals-and-sandbox --model gpt-5.5 -c model_reasoning_effort="xhigh"'

# --- bat ---
if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
  alias less='bat --paging=always'
  alias catp='bat --plain --paging=never'
  alias batdiff='bat --diff'
  alias help='bat --plain --language=help'
fi

if command -v pip3 &>/dev/null; then
  alias pip=pip3
elif command -v python3 &>/dev/null; then
  alias pip='python3 -m pip'
fi

# --- PATH (portable) ---
path_prepend() {
  local dir
  for dir in "$@"; do
    [[ -d "$dir" ]] || continue
    case ":$PATH:" in
      *":$dir:"*) ;;
      *) PATH="$dir:$PATH" ;;
    esac
  done
}

path_prepend \
  "$HOME/.local/bin" \
  "$HOME/bin" \
  "$HOME/.dotnet/tools" \
  "$HOME/.opencode/bin" \
  "$HOME/.lmstudio/bin" \
  "$HOME/.grok/bin"

# User Python scripts (macOS often uses ~/Library/Python/*/bin)
for _py_bin in "$HOME"/Library/Python/*/bin(N); do
  path_prepend "$_py_bin"
done
unset _py_bin

export PATH

# --- OS-specific ---
case "$(uname -s)" in
  Darwin) [[ -f "$DOTFILES/zsh/os-darwin.zsh" ]] && source "$DOTFILES/zsh/os-darwin.zsh" ;;
  Linux)  [[ -f "$DOTFILES/zsh/os-linux.zsh" ]]  && source "$DOTFILES/zsh/os-linux.zsh" ;;
esac

# --- bun ---
export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
path_prepend "$BUN_INSTALL/bin"
export PATH
[[ -s "$BUN_INSTALL/_bun" ]] && source "$BUN_INSTALL/_bun"

# --- yazi: y -> yazi ---
[[ -f "$DOTFILES/zsh/yazi.zsh" ]] && source "$DOTFILES/zsh/yazi.zsh"